generator client {
  provider = "prisma-client-js" 
}

datasource db {
  provider = "postgresql"
  
}
model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  name       String?
  googleId   String     @unique
  categories Category[] // Link to categories
}
model Category {
  id       Int           @id @default(autoincrement())
  name     String
  userId        Int           // The owner of this category
  user          User          @relation(fields: [userId], references: [id])
  children SubCategory[]
}

model SubCategory {
  id         Int      @id @default(autoincrement())
  name       String
  count      Int      @default(0)
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}